# Copier en .env — jamais de vrai secret dans ce fichier d'exemple (ADR-010).
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
WORKER_MODE=all
DATABASE_URL=postgres://hgc:hgc@localhost:5432/hgc
LOG_LEVEL=info

# OIDC — Keycloak local en dev (docker-compose.dev.yml), Switch edu-ID en prod.
# Branché au fil du jalon M1 (module auth).
OIDC_ISSUER=http://localhost:8080/realms/hgc-dev
OIDC_CLIENT_ID=hgc-portal
OIDC_CLIENT_SECRET=dev-secret-not-for-production

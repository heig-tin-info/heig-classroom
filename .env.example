# Copier en .env — jamais de vrai secret dans ce fichier d'exemple (ADR-010).
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
WORKER_MODE=all
DATABASE_URL=postgres://hgc:hgc@localhost:5432/hgc
LOG_LEVEL=info

# OIDC — Keycloak local en dev (docker-compose.dev.yml), Switch edu-ID en prod.
PUBLIC_URL=http://localhost:3000
OIDC_ISSUER=http://localhost:8080/realms/hgc-dev
OIDC_CLIENT_ID=hgc-portal
OIDC_CLIENT_SECRET=dev-secret-not-for-production
COOKIE_SECRET=dev-cookie-secret-change-me
SESSION_TTL_HOURS=12

# Teachers provisionnés par liste d'e-mails (H2 : pas de rôle admin en v1).
TEACHER_EMAILS=teacher@heig-vd.ch

# GitHub App (provisionnement, webhooks) — créée dans l'organisation cible,
# permissions selon GH-02 (docs/02). Le PEM vit dans secrets/ (gitignoré).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=secrets/hgc-dev.private-key.pem
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# OAuth App (liaison du compte GitHub des étudiants, scope read:user)
# Callback : http://localhost:3000/app/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

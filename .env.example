# Copy to .env -- never put a real secret in this example file (ADR-010).
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
WORKER_MODE=all
DATABASE_URL=postgres://hgc:hgc@localhost:5432/hgc
LOG_LEVEL=info

# OIDC -- local Keycloak in dev (docker-compose.dev.yml), Switch edu-ID in prod.
PUBLIC_URL=http://localhost:3000
OIDC_ISSUER=http://localhost:8080/realms/hgc-dev
OIDC_CLIENT_ID=hgc-portal
OIDC_CLIENT_SECRET=dev-secret-not-for-production
COOKIE_SECRET=dev-cookie-secret-change-me
# Idle timeout: sessions renew while in use (sliding expiry). Max 720 (30 days).
SESSION_TTL_HOURS=12

# Super administrator (manages teachers from the portal's admin screen).
SUPER_ADMIN_EMAIL=teacher@heig-vd.ch

# GitHub App (provisioning, webhooks) -- created inside the target organization,
# permissions per GH-02 (docs/02). The PEM lives in secrets/ (gitignored).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=secrets/hgc-dev.private-key.pem
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# OAuth App (links the students' GitHub accounts, read:user scope)
# Callback: http://localhost:3000/app/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Email provider (Scaleway Transactional Email). Without SCW_SECRET_KEY +
# SCW_DEFAULT_PROJECT_ID the mailer dry-runs: emails are logged, never sent.
# The sending domain (MAIL_FROM) must be validated in the Scaleway console
# (SPF/DKIM/DMARC), or everything lands in spam.
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_DEFAULT_ORGANIZATION_ID=
SCW_DEFAULT_PROJECT_ID=
MAIL_FROM=no-reply@classroom.chevallier.io
MAIL_FROM_NAME=HEIG Classroom
MAIL_REGION=fr-par
